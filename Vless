#!/bin/bash

# 1. Enable necessary Google Cloud APIs
echo "Enabling required APIs..."
gcloud services enable run.googleapis.com cloudbuild.googleapis.com

# 2. Setup the directory properly
WORKDIR="$HOME/vless-deploy"
if [ ! -d "$WORKDIR" ]; then
    mkdir -p "$WORKDIR"
fi
cd "$WORKDIR" || { echo "Failed to access $WORKDIR"; exit 1; }

# 3. Ask for user input (Fixed for curl | bash)
echo "Enter your desired Cloud Run service name:"
# The < /dev/tty allows you to type even when using curl | bash
read MY_SERVICE_NAME < /dev/tty

# Check if the input is empty
if [ -z "$MY_SERVICE_NAME" ]; then
    echo "❌ Error: Service name cannot be empty. Please run the script again."
    exit 1
fi

# 4. Create the package.json
cat <<EOF > package.json
{
  "name": "hub7s-minimal",
  "version": "1.2.0",
  "main": "app.js",
  "scripts": {
    "start": "node app.js"
  },
  "dependencies": {
    "ws": "^8.14.2"
  }
}
EOF

# 5. Create the app.js
cat <<EOF > app.js
const http = require('http');
const net = require('net');
const { WebSocket, createWebSocketStream } = require('ws');

const UUID = process.env.UUID || 'aaaaaaa7-bbbb-7ccc-accc-eeeeeeeeeee7';
const PORT = process.env.PORT || '8080';
const VL_NAME = 'CloudRun-Vless';

const CUSTOM_ADDRESS = 'firebase-settings.crashlytics.com';
const CUSTOM_SNI = 'cares.paymaya.com';

const httpServer = http.createServer((req, res) => {
    const host = req.headers.host;
    if (req.url === '/') {
        const vlessURL = \`vless://\${UUID}@\${CUSTOM_ADDRESS}:443?path=%2F&security=tls&encryption=none&host=\${host}&type=ws&sni=\${CUSTOM_SNI}#\${VL_NAME}\`;
        res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
        res.write(\`
        <!DOCTYPE html>
        <html lang="en">
        <head>
            <meta charset="UTF-8">
            <title>Vless Config</title>
            <meta name="viewport" content="width=device-width, initial-scale=1">
            <style>
                body { background-color: #0d1117; color: #c9d1d9; font-family: sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; margin: 0; }
                .card { background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 2.5rem; width: 90%; max-width: 420px; text-align: center; }
                h2 { color: #58a6ff; }
                textarea { width: 100%; height: 120px; background: #010409; color: #7ee787; border: 1px solid #30363d; border-radius: 8px; padding: 12px; resize: none; margin-bottom: 25px; }
                button { background-color: #238636; color: #ffffff; border: none; border-radius: 6px; padding: 14px 0; cursor: pointer; font-weight: 600; width: 100%; }
            </style>
        </head>
        <body>
            <div class="card">
                <h2>Vless Protocol</h2>
                <textarea id="vlessConfig" readonly>\${vlessURL}</textarea>
                <button onclick="copyLink()">Copy Config</button>
            </div>
            <script>
                function copyLink() {
                    const copyText = document.getElementById("vlessConfig");
                    copyText.select();
                    navigator.clipboard.writeText(copyText.value);
                    alert("Config copied!");
                }
            </script>
        </body>
        </html>\`);
        res.end();
    } else {
        res.writeHead(404);
        res.end();
    }
});

const wss = new WebSocket.Server({ server: httpServer });
const uuidClean = UUID.replace(/-/g, "");

wss.on('connection', ws => {
    ws.once('message', msg => {
        const [VERSION] = msg;
        const id = msg.slice(1, 17);
        if (!id.every((v, i) => v == parseInt(uuidClean.substr(i * 2, 2), 16))) return;
        let i = msg.slice(17, 18).readUInt8() + 19;
        const port = msg.slice(i, i += 2).readUInt16BE(0);
        const ATYP = msg.slice(i, i += 1).readUInt8();
        const host = ATYP == 1 ? msg.slice(i, i += 4).join('.') : 
                     (ATYP == 2 ? new TextDecoder().decode(msg.slice(i + 1, i += 1 + msg.slice(i, i + 1).readUInt8())) : 
                     (ATYP == 3 ? msg.slice(i, i += 16).reduce((s, b, i, a) => (i % 2 ? s.concat(a.slice(i - 1, i + 1)) : s), []).map(b => b.readUInt16BE(0).toString(16)).join(':') : ''));
        
        ws.send(new Uint8Array([VERSION, 0]));
        const duplex = createWebSocketStream(ws);
        net.connect({ host, port }, function () {
            this.write(msg.slice(i));
            duplex.on('error', () => { }).pipe(this).on('error', () => { }).pipe(duplex);
        }).on('error', () => { });
    }).on('error', () => { });
});

httpServer.listen(PORT, () => {
    console.log('Listening on ' + PORT);
});
EOF

# 6. Final Deploy
echo "🚀 Deploying $MY_SERVICE_NAME to Cloud Run..."
gcloud run deploy "$MY_SERVICE_NAME" \
  --source . \
  --region us-central1 \
  --allow-unauthenticated \
  --set-env-vars UUID="aaaaaaa7-bbbb-7ccc-accc-eeeeeeeeeee7" \
  --port 8080 \
  --timeout=3600 \
  --concurrency=1000 \
  --cpu=1 \
  --memory=512Mi \
  --quiet
